# Copy this file to .env and fill in your values.
# NEVER commit .env — it is gitignored.

# Anthropic
ANTHROPIC_API_KEY=

# GitHub
GITHUB_TOKEN=

# AI tools
CONTEXT7_API_KEY=

# OpenAI (used by tools/ocr)
OPENAI_API_KEY=

# OCR inbox directory — folder where PDFs are dropped for processing
# Processed files will be moved to $OCR_INBOX_DIR/processed/
OCR_INBOX_DIR=/path/to/your/inbox
